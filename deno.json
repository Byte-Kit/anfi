{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/tags/v2.5.0/cli/schemas/config-file.v1.json",
  "permissions": {
    "default": {
      "env": [
        "CI",
        "COLORTERM",
        "CONTINUOUS_INTEGRATION",
        "DB_MIGRATION_PATH",
        "DB_PATH",
        "DEV",
        "HOME",
        "INK_SCREEN_READER",
        "NODE_ENV",
        "PORT",
        "TEAMCITY_VERSION",
        "TERM",
        "TERM_PROGRAM",
        "TERM_PROGRAM_VERSION",
        "TF_BUILD",
        "TMUX"
      ],
      "read": [
        "./migrations/",
        "./output/"
      ],
      "write": [
        "./output/"
      ]
    }
  },
  "test": {
    "permissions": {
      "env": [
        "HOME",
        "PORT",
        "DB_PATH",
        "DB_MIGRATION_PATH"
      ],
      "read": [
        "./migrations/",
        "./output/"
      ],
      "write": [
        "./output/"
      ]
    }
  },
  "tasks": {
    "ci:lint": "deno lint",
    "ci:fmt": "deno fmt --check src/",
    "ci:check": "deno check",
    "ci": {
      "command": "deno task coverage",
      "dependencies": [
        "ci:fmt",
        "ci:lint",
        "ci:check",
        "test"
      ]
    },
    "db:clean": "deno run -P --env-file=.env src/scripts/db/clean.ts",
    "db:migrate": "deno run -P --env-file=.env src/scripts/db/migrate.ts",
    "db:reset": "deno run db:clean; deno run db:migrate",
    "coverage": "deno coverage --exclude=\"model\" --exclude=\"db\"",
    "dev:cli": "deno run -P --env-file=.env src/cli/index.ts",
    "dev:tui": "deno run -P --env-file=.env src/tui/index.tsx",
    "test": "deno test -P --env-file=.env.test --coverage",
    "test:watch": "deno test -P --env-file=.env.test --watch",
    "build:cli": "deno compile --output=./build/anfi -P --env-file=.env src/cli/index.ts"
  },
  "imports": {
    "@anfi/": "./src/",
    "@anfi/business": "./src/business/index.ts",
    "@anfi/db": "./src/db/index.ts",
    "@anfi/lib": "./src/lib/index.ts",
    "@anfi/model": "./src/model/index.ts",
    "@anfi/model/repository": "./src/model/repository/index.ts",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/fs": "jsr:@std/fs@^1.0.22",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/testing": "jsr:@std/testing@1",
    "@types/react": "npm:@types/react@^19.2.13",
    "ink": "npm:ink@^6.6.0",
    "react": "npm:react@^19.2.4",
    "zod": "npm:zod@^4.3.6"
  },
  "fmt": {
    "operatorPosition": "nextLine"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended",
        "react"
      ]
    }
  }
}
